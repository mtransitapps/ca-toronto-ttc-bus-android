{
    "default_route_id_enabled": true,
    "use_route_short_name_for_route_id": true,
    "default_route_long_name_enabled": true,
    "route_colors_ignored": [
        "D5C82B",
        "008000",
        "B300B3"
    ],
    "direction_finder_enabled": true,
    "direction_types": [
        1
    ],
    "direction_types_comment": "direction cardinal type",
    "direction_headsign_cleaners_comment": "Cardinal - 00(Z?) xxx towards yyy",
    "direction_headsign_cleaners": [
        {
            "regex": " - \\d+.*$"
        }
    ],
    "trip_excludes": [
        {
            "trip_headsign_regex": "(not in service)",
            "ignore_case": true
        }
    ],
    "trip_headsign_remove_via": true,
    "trip_headsign_cleaners_comment": "Cardinal - 00(Z?) xxx towards yyy",
    "stop_headsign_cleaners_comment": "00(Z?) xxx towards yyy",
    "stop_name_cleaners": [
        {
            "regex": "side",
            "ignore_case": true,
            "is_word": true
        },
        {
            "regex": "(H\\.S\\.)",
            "ignore_case": true,
            "replacement": "HS"
        },
        {
            "regex": "(s\\.S\\.)",
            "ignore_case": true,
            "replacement": "SS"
        },
        {
            "regex": "(C\\.N\\.R\\.)",
            "ignore_case": true,
            "replacement": "CNR"
        },
        {
            "regex": "(C\\.\\s*N\\.)",
            "ignore_case": true,
            "replacement": "CN"
        },
        {
            "regex": "(C\\.I\\.)",
            "ignore_case": true,
            "replacement": "CI"
        },
        {
            "regex": "(II)",
            "ignore_case": true,
            "replacement": "II"
        },
        {
            "regex": "((^|\\W)(GO)(\\W|$))",
            "ignore_case": true,
            "replacement": "$2GO$4"
        }
    ]
}